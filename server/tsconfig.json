{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"]       // << asegura que TS cargue Node y Jest
  },
  "include": [
    "src/**/*.ts",
    "src/__test__/**/*.ts"          // << incluye tus tests
  ]
}
