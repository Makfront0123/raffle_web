{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs -d src/data-source.ts migration:generate",
    "migration:run:local": "typeorm-ts-node-commonjs -d src/data-source.ts migration:run",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js -d dist/data-source.js migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/data-source.ts migration:revert",
    "seed:all": "ts-node src/seeder/allSeeder.ts",
    "stress": "ts-node src/seeder/stress_test.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^25.0.3",
    "@types/supertest": "^6.0.3",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.15.1",
    "node-cron": "^4.2.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.4",
    "twilio": "^5.11.1",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "29",
    "@types/jsonwebtoken": "^9.0.10",
    "jest": "29",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-jest": "29",
    "ts-node": "^10.9.2"
  }
}